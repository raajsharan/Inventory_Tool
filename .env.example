# Root-level .env is optional. The actual runtime env files live at:
#   backend/.env       (see backend/.env.example)
#   frontend/.env      (see frontend/.env.example)
#
# This file is a convenience reference for shared values used by deploy/setup.sh:
PROJECT_DIR=/opt/inventory
DB_NAME=inventory_db
DB_USER=inventory_user
# DB_PASSWORD will be auto-generated by deploy/setup.sh if unset
